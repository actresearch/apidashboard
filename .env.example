# GHCR image used by Portainer stack
GHCR_IMAGE=ghcr.io/actresearch/apidashboard:latest

# Host port mapped to container port 5005
APP_PORT=5005

# Absolute host path for the bind mount on the Docker server
DASHBOARD_LOG_PATH=/opt/api-dashboard/logs
API_HEALTH_STREAM_URL=http://192.168.1.17:5002/stream
WATCHDOG_STREAM_URL=http://192.168.1.17:8001/stream

# Supabase API request log source for 30-day dashboard usage lists
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_LOG_TIMESTAMP_COLUMN=created_at
